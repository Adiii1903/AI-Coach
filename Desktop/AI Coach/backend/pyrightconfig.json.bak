{
    "include": [
        "app",
        "main.py",
        "alembic"
    ],
    "exclude": [
        "**/__pycache__"
    ],
    "venvPath": ".",
    "venv": "venv",
    "pythonVersion": "3.13",
    "typeCheckingMode": "basic",
    "reportMissingImports": "none",
    "reportMissingModuleSource": "none",
    "extraPaths": [
        "."
    ]
}