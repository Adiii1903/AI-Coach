{
    "include": [
        "backend/app",
        "backend/main.py",
        "backend/alembic"
    ],
    "exclude": [
        "**/__pycache__"
    ],
    "venvPath": "backend",
    "venv": "venv",
    "pythonVersion": "3.13",
    "typeCheckingMode": "basic",
    "reportMissingImports": "none",
    "reportMissingModuleSource": "none",
    "extraPaths": [
        "backend"
    ]
}